{
  "version": "0.2.0",
  "configurations": [
    {
      "name": "Hono: Debug API (Node Stable Async)",
      "type": "node",
      "request": "launch",
      "cwd": "${workspaceFolder}/packages/server",
      "runtimeExecutable": "node",
      "runtimeArgs": ["--import", "tsx", "--enable-source-maps"],
      "program": "${workspaceFolder}/packages/server/src/node.ts",
      "console": "integratedTerminal",
      "internalConsoleOptions": "neverOpen",
      "skipFiles": [
        "<node_internals>/**",
        "${workspaceFolder}/**/node_modules/**"
      ],
      "env": {
        "NODE_OPTIONS": "--enable-source-maps"
      }
    },
    {
      "name": "Hono: Debug API (Wrangler Fallback)",
      "type": "node-terminal",
      "request": "launch",
      "command": "pnpm -C packages/server dev -- --inspector-port=9229",
      "cwd": "${workspaceFolder}",
      "autoAttachChildProcesses": true,
      "skipFiles": [
        "<node_internals>/**",
        "${workspaceFolder}/**/node_modules/**"
      ]
    }
  ]
}
